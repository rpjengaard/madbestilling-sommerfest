@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Gennemfør din bestilling";

    var pageSubtitle    = Model.Value<string>("subtitle") ?? "Sommer Festival 2026";
    var mobilePayBoxNr  = Model.Value<string>("mobilePayBoxNumber") ?? "[BOXNUMMER]";

    var orderPage = Model.Parent?.Children
        .FirstOrDefault(c => c.ContentType.Alias == "orderPage");
    var backUrl = orderPage?.Url() ?? "/";

    var isSuccess = Context.Request.Query["success"] == "true";

    var payBoxNr   = TempData["Payment_BoxNr"]   as string ?? string.Empty;
    var payAmount  = TempData["Payment_Amount"]  as string ?? string.Empty;
    var payMessage = TempData["Payment_Message"] as string ?? string.Empty;
}

@if (isSuccess && !string.IsNullOrEmpty(payBoxNr))
{
    <div id="paymentModal" class="fixed inset-0 z-50 flex items-center justify-center px-4" style="background:rgba(0,0,0,.45);">
        <div class="bg-white rounded-[24px] shadow-2xl w-full max-w-md p-8 flex flex-col gap-6 animate-fade-in">

            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-600" viewBox="0 0 24 24" fill="none">
                            <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h2 class="text-xl font-black text-[#1e3a6e]">Bestilling modtaget!</h2>
                </div>
                <button onclick="document.getElementById('paymentModal').remove()" class="text-gray-300 hover:text-gray-500 text-2xl leading-none font-light">&times;</button>
            </div>

            <p class="text-sm text-gray-500">Du modtager en kvittering på e-mail. Husk at betale med MobilePay:</p>

            <div class="bg-[#f4c200] rounded-[16px] p-5 flex flex-col gap-3">
                <p class="font-black text-[#1a2d5a] text-base">Betal med MobilePay med nedenstående oplysninger</p>
                <div class="flex flex-col gap-2 text-sm text-[#1a2d5a]">
                    <div class="flex justify-between">
                        <span class="font-semibold">Box nummer</span>
                        <span class="font-black text-lg tracking-wide">@payBoxNr</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="font-semibold">Beløb</span>
                        <span class="font-black text-lg">@payAmount kr.</span>
                    </div>
                    <div class="border-t border-[#d4a900]/40 pt-2">
                        <span class="font-semibold block mb-1">Besked i MobilePay</span>
                        <span class="font-black break-all">@payMessage</span>
                    </div>
                </div>
            </div>

            <p class="text-xs text-gray-400 text-center">Husk den korrekte besked, så vi kan identificere din betaling ved afhentning.</p>

            <button onclick="document.getElementById('paymentModal').remove()"
                    class="bg-[#2d4b8a] hover:bg-[#1e3870] text-white font-bold text-sm py-3 px-8 rounded-full transition-colors w-full">
                Forstået – luk
            </button>
        </div>
    </div>
}

<div class="min-h-screen bg-gradient-to-br from-[#edf1fa] to-[#e5ecf7] px-6 py-10">
    <div class="max-w-[1100px] mx-auto">

        @if (isSuccess)
        {
            <div class="bg-green-500 text-white rounded-[16px] px-6 py-4 mb-6 font-semibold text-sm">
                Din bestilling er sendt! Du modtager en kvittering på e-mail.
            </div>
        }

        <!-- Page header -->
        <a href="@backUrl" class="inline-flex items-center gap-2 text-sm font-semibold text-[#1e3a6e]/60 hover:text-[#1e3a6e] transition-colors mb-6">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M5 12l7 7M5 12l7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Tilbage til bestilling
        </a>
        <h1 class="text-5xl font-black text-[#1e3a6e] mb-1">Gennemfør din bestilling</h1>
        <p class="text-sm text-gray-400 mb-10">@pageSubtitle</p>

        <div class="grid grid-cols-[1fr_340px] gap-6 items-start max-lg:grid-cols-1">

            <!-- ═══════════════════════ LEFT COLUMN ══ -->
            <div class="flex flex-col gap-5">

                <!-- Kundeoplysninger -->
                <div class="bg-white rounded-[20px] shadow-sm p-7">
                    <header class="flex items-center gap-3 mb-6">
                        <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <h2 class="text-lg font-black text-primary">Kundeoplysninger</h2>
                    </header>

                    <form id="checkoutForm"
                          method="post"
                          action="/umbraco/surface/CheckoutSurface/SubmitOrder"
                          class="flex flex-col gap-5">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="cartJson" id="cartJson" />
                        <input type="hidden" name="mobilePayBoxNumber" value="@mobilePayBoxNr" />
                        <input type="hidden" name="returnUrl" value="@Model.Url()" />

                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-app-text" for="childName">Dit barns navn</label>
                            <input id="childName" name="childName" type="text"
                                   placeholder="F.eks. Olivia Nørgaard"
                                   class="w-full bg-[#e8eaef] rounded-full px-5 py-3.5 text-sm text-app-text placeholder-gray-400 outline-none focus:ring-2 focus:ring-primary/20 transition" />
                            <p class="text-xs text-red-500 hidden" id="childNameError">Udfyld venligst dit barns navn.</p>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-app-text" for="childClass">Barnets Klasse</label>
                            <input id="childClass" name="childClass" type="text"
                                   placeholder="F.eks. 3.B"
                                   class="w-full bg-[#e8eaef] rounded-full px-5 py-3.5 text-sm text-app-text placeholder-gray-400 outline-none focus:ring-2 focus:ring-primary/20 transition" />
                            <p class="text-xs text-red-500 hidden" id="childClassError">Udfyld venligst barnets klasse.</p>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-app-text" for="phone">Mobil nummer</label>
                            <input id="phone" name="phone" type="tel"
                                   placeholder="F.eks. 12 34 56 78"
                                   class="w-full bg-[#e8eaef] rounded-full px-5 py-3.5 text-sm text-app-text placeholder-gray-400 outline-none focus:ring-2 focus:ring-primary/20 transition" />
                            <p class="text-xs text-red-500 hidden" id="phoneError">Udfyld venligst dit mobilnummer.</p>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-app-text" for="email">Din e-mail <span class="font-normal text-gray-400">(bruges til kvittering)</span></label>
                            <input id="email" name="email" type="email"
                                   placeholder="f.eks. mette@email.dk"
                                   class="w-full bg-[#e8eaef] rounded-full px-5 py-3.5 text-sm text-app-text placeholder-gray-400 outline-none focus:ring-2 focus:ring-primary/20 transition" />
                            <p class="text-xs text-red-500 hidden" id="emailError">Udfyld venligst din e-mail.</p>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label class="text-sm font-semibold text-app-text" for="emailConfirm">Bekræft E-mail</label>
                            <input id="emailConfirm" name="emailConfirm" type="email"
                                   placeholder="Gentag din e-mail"
                                   class="w-full bg-[#e8eaef] rounded-full px-5 py-3.5 text-sm text-app-text placeholder-gray-400 outline-none focus:ring-2 focus:ring-primary/20 transition" />
                            <p class="text-xs text-red-500 hidden" id="emailConfirmError">E-mailerne stemmer ikke overens.</p>
                        </div>
                    </form>
                </div>

                <!-- MobilePay -->
                <div class="bg-white rounded-[20px] shadow-sm p-7">
                    <header class="flex items-center gap-3 mb-5">
                        <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none">
                            <rect x="5" y="2" width="14" height="20" rx="2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            <line x1="12" y1="18" x2="12.01" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <h2 class="text-lg font-black text-primary">Betal med MobilePay Box</h2>
                    </header>

                    <div class="bg-[#f3f5f9] rounded-[14px] p-5 mb-4 flex flex-col gap-4">

                        <div>
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Box nummer</p>
                            <p class="text-base font-black text-primary">@mobilePayBoxNr</p>
                        </div>

                        <div>
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Beløb</p>
                            <p class="text-base font-black text-primary" id="mpAmount">–</p>
                        </div>

                        <div>
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Besked</p>
                            <p class="text-base font-black text-primary" id="mpMessage">–</p>
                        </div>

                    </div>

                    <div class="flex gap-3 items-start">
                        <svg class="w-4 h-4 text-primary shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none">
                            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.8"/>
                            <line x1="12" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                            <line x1="12" y1="16" x2="12.01" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            Husk at skrive ovenstående besked i beskedfeltet i MobilePay, så vi kan identificere din betaling ved afhentning.
                        </p>
                    </div>
                </div>

            </div>

            <!-- ═══════════════════════ RIGHT SIDEBAR ══ -->
            <aside class="sticky top-6 max-lg:order-first">
                <div class="bg-primary rounded-[20px] p-6 text-white flex flex-col gap-5">

                    <header class="flex items-center gap-4">
                        <span class="w-14 h-14 bg-white/15 rounded-full flex items-center justify-center shrink-0" aria-hidden="true">
                            <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none">
                                <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                                <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                                <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <h2 class="text-2xl font-extrabold tracking-[.06em] uppercase">Din Bestilling</h2>
                    </header>

                    <ul class="flex flex-col gap-0" id="checkoutCartList">
                        <!-- filled by JS -->
                    </ul>
                    <p class="text-sm text-white/50 text-center" id="checkoutCartEmpty">Ingen varer i kurven.</p>

                    <div class="border-t border-white/20 pt-4" id="checkoutTotals" hidden>
                        <div class="flex justify-between items-baseline">
                            <span class="text-sm text-white/60 font-semibold">Samlet total</span>
                            <strong class="text-3xl font-black" id="checkoutTotal">0,00 kr.</strong>
                        </div>
                    </div>

                    <button type="button"
                            id="submitOrderBtn"
                            class="flex items-center justify-center gap-2 bg-accent hover:bg-yellow-400 text-app-text font-black rounded-full py-3.5 px-5 w-full transition-colors text-sm">
                        Send bestilling
                    </button>

                    <p class="text-[.7rem] text-white/50 text-center leading-relaxed">
                        Vi sender en kvittering på mail (hvis du har angivet din mailadresse)
                    </p>

                </div>
            </aside>

        </div>
    </div>
</div>

<!-- Checkout cart item template -->
<template id="checkoutItemTpl">
    <li class="flex items-center gap-3 py-3 border-b border-white/10 last:border-0 last:pb-0 first:pt-0">
        <img class="w-10 h-10 rounded-xl object-cover shrink-0" />
        <div class="flex flex-col flex-1 min-w-0 gap-1">
            <span class="text-sm font-bold truncate" data-name></span>
            <div class="flex items-center gap-2">
                <button type="button" data-decrease
                        class="w-5 h-5 rounded-full bg-white/15 hover:bg-white/30 flex items-center justify-center text-xs font-bold transition-colors disabled:opacity-30 disabled:cursor-not-allowed">−</button>
                <span class="text-xs font-semibold w-4 text-center tabular-nums" data-qty></span>
                <button type="button" data-increase
                        class="w-5 h-5 rounded-full bg-white/15 hover:bg-white/30 flex items-center justify-center text-xs font-bold transition-colors">+</button>
            </div>
        </div>
        <span class="text-sm font-bold whitespace-nowrap" data-price></span>
        <button type="button" data-remove aria-label="Fjern vare"
                class="text-white/30 hover:text-white/80 transition-colors text-lg leading-none px-1 ml-1">×</button>
    </li>
</template>

@section Scripts {
<script>
(() => {
    const STORAGE_KEY = 'fo_cart';
    let cart = [];
    try { cart = JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; } catch {}

    function save() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(cart));
    }

    function formatDKK(amount) {
        return amount.toLocaleString('da-DK', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function render() {
        const list    = document.getElementById('checkoutCartList');
        const empty   = document.getElementById('checkoutCartEmpty');
        const totals  = document.getElementById('checkoutTotals');
        const totalEl = document.getElementById('checkoutTotal');
        const tpl     = document.getElementById('checkoutItemTpl');

        list.innerHTML = '';

        if (cart.length === 0) {
            empty.hidden  = false;
            totals.hidden = true;
            document.getElementById('cartJson').value = '[]';
            return;
        }

        empty.hidden  = true;
        totals.hidden = false;

        let total = 0;
        cart.forEach(item => {
            total += item.price * item.qty;

            const fragment   = tpl.content.cloneNode(true);
            const img        = fragment.querySelector('img');
            img.src = item.image;
            img.alt = item.name;

            fragment.querySelector('[data-name]').textContent  = item.name;
            fragment.querySelector('[data-qty]').textContent   = item.qty;
            fragment.querySelector('[data-price]').textContent = formatDKK(item.price * item.qty) + ' kr.';

            const decreaseBtn = fragment.querySelector('[data-decrease]');
            decreaseBtn.disabled = item.qty <= 1;
            decreaseBtn.addEventListener('click', () => {
                const entry = cart.find(i => i.id === item.id);
                if (entry && entry.qty > 1) { entry.qty--; save(); render(); }
            });

            fragment.querySelector('[data-increase]').addEventListener('click', () => {
                const entry = cart.find(i => i.id === item.id);
                if (entry) { entry.qty++; save(); render(); }
            });

            fragment.querySelector('[data-remove]').addEventListener('click', () => {
                cart = cart.filter(i => i.id !== item.id);
                save();
                render();
            });

            list.appendChild(fragment);
        });

        totalEl.textContent = formatDKK(total) + ' kr.';
        document.getElementById('cartJson').value = JSON.stringify(cart);
        updateMobilePay(total);
    }

    function updateMobilePay(total) {
        const childName  = document.getElementById('childName').value.trim();
        const childClass = document.getElementById('childClass').value.trim();

        const amountEl  = document.getElementById('mpAmount');
        const messageEl = document.getElementById('mpMessage');

        amountEl.textContent  = total > 0 ? formatDKK(total) + ' kr.' : '–';

        const phone = document.getElementById('phone').value.trim();
        const hasName = childClass || childName;
        messageEl.textContent = hasName
            ? `${childClass} - ${childName}${phone ? ` (${phone})` : ''}`
            : '–';
    }

    function setError(id, visible) {
        document.getElementById(id).classList.toggle('hidden', !visible);
    }

    function validateAndSubmit() {
        const childName    = document.getElementById('childName').value.trim();
        const childClass   = document.getElementById('childClass').value.trim();
        const phone        = document.getElementById('phone').value.trim();
        const email        = document.getElementById('email').value.trim();
        const emailConfirm = document.getElementById('emailConfirm').value.trim();

        const childNameInvalid    = childName === '';
        const childClassInvalid   = childClass === '';
        const phoneInvalid        = phone === '';
        const emailInvalid        = email === '';
        const emailConfirmInvalid = emailConfirm === '' || email !== emailConfirm;

        setError('childNameError',    childNameInvalid);
        setError('childClassError',   childClassInvalid);
        setError('phoneError',        phoneInvalid);
        setError('emailError',        emailInvalid);
        setError('emailConfirmError', emailConfirmInvalid);

        if (childNameInvalid || childClassInvalid || phoneInvalid || emailInvalid || emailConfirmInvalid) {
            document.querySelector('[id$="Error"]:not(.hidden)')?.previousElementSibling?.focus();
            return;
        }

        document.getElementById('checkoutForm').submit();
    }

    document.getElementById('childName').addEventListener('input', () => updateMobilePay(currentTotal()));
    document.getElementById('childClass').addEventListener('input', () => updateMobilePay(currentTotal()));
    document.getElementById('phone').addEventListener('input', () => updateMobilePay(currentTotal()));

    function currentTotal() {
        return cart.reduce((sum, i) => sum + i.price * i.qty, 0);
    }

    if (new URLSearchParams(window.location.search).get('success') === 'true') {
        localStorage.removeItem('fo_cart');
    }

    document.getElementById('submitOrderBtn').addEventListener('click', validateAndSubmit);
    render();
})();
</script>
}